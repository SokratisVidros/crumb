{
  "name": "humantrail",
  "scripts": {
    "dev": "NODE_ENV=development bun run --hot src/index.ts",
    "sample": "bun run scripts/sample.ts",
    "sample:track:pixel": "bun run scripts/sample.ts",
    "sample:track:click": "bun run scripts/sample.ts -- --click",
    "sample:track:api": "bun run scripts/sample.ts -- --api",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "commander": "^14.0.3",
    "hono": "^4.12.2",
    "table": "^6.9.0",
    "ua-parser-js": "^2.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "latest",
    "@types/ua-parser-js": "^0.7.39",
    "typescript": "^5.9.3"
  }
}
